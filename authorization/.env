AUTHORIZATION_SERVER_PORT=9000
AUTHORIZATION_POSTGRES_DB=authorizationdb
AUTHORIZATION_POSTGRES_USER=my_user
AUTHORIZATION_POSTGRES_PASSWORD=my_pswd
AUTHORIZATION_POSTGRES_HOST=localhost
AUTHORIZATION_POSTGRES_PORT=5432

POD_NAME=authorization-pod
APP_IMAGE=authorization_spring
DB_IMAGE=postgres:alpine
KUBE_OUTPUT=pod.yaml

AUTHORIZATION_SERVER_ISSUER=http://localhost:8080
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0

SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=admin
SUPERUSER_FIRST_NAME=Admin
SUPERUSER_LAST_NAME=Super
